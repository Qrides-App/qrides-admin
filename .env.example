#############################################
# Qrides Backend - Production Env Template
#############################################
# 1) Copy this file to .env
# 2) Fill real secrets and URLs
# 3) Run:
#    php artisan key:generate --force
#    php artisan config:clear
#    php artisan cache:clear
#    php artisan route:clear

APP_NAME=Qrides
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.your-domain.com
ASSET_URL=${APP_URL}

# Legacy app switches used by this project build
APP_INSTALL=true
APP_MODE=live
PURCHASE_CODE=

LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

BROADCAST_DRIVER=log
FILESYSTEM_DISK=public
CACHE_DRIVER=file
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.your-domain.com
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=admin.your-domain.com,api.your-domain.com
SANCTUM_ISSUE_SECRET=replace_with_64_char_random_secret
ALLOW_GUEST_TOKENS=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qrides
DB_USERNAME=qrides_user
DB_PASSWORD=change_me
DB_SOCKET=
MYSQL_ATTR_SSL_CA=
DB_FOREIGN_KEYS=true

# Optional Laravel MongoDB connection (only if used)
DB_MONGO_CONNECTION=mongodb
DB_URI=
DB_DATABASE_MONGO=

# Custom Mongo usage in services (used by ride data service)
MONGO_DSN=
MONGO_DB=3rees

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=qrides_database_
REDIS_QUEUE=default

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_EHLO_DOMAIN=
MAIL_LOG_CHANNEL=
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"

# Push provider keys (optional)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
ABLY_KEY=

# AWS / S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
SQS_PREFIX=
SQS_QUEUE=default
SQS_SUFFIX=

# Cache backends (optional)
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_PERSISTENT_ID=
CACHE_PREFIX=qrides_cache_
DYNAMODB_CACHE_TABLE=cache
DYNAMODB_ENDPOINT=

# External email services (optional)
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
POSTMARK_TOKEN=

# Crash/debug tools in production should remain off
DEBUGBAR_ENABLED=false
DEBUGBAR_EDITOR=phpstorm
DEBUGBAR_THEME=auto
DEBUGBAR_OPEN_STORAGE=
DEBUGBAR_REMOTE_SITES_PATH=
DEBUGBAR_LOCAL_SITES_PATH=
IGNITION_EDITOR=phpstorm
IGNITION_LOCAL_SITES_PATH=

# Security / hashing
BCRYPT_ROUNDS=12
DEMO_MODE=false
CORS_ALLOWED_ORIGINS=https://admin.qrides.in,https://qrides.in,https://www.qrides.in
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,X-Requested-With,Authorization,Accept,Origin
CORS_SUPPORTS_CREDENTIALS=false

#############################################
# PAYMENT GATEWAYS
#############################################
# Razorpay (required if recharge/payment via Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Legacy fallback key used in webhook controller
RAZORPAY_KEY=

# Cashfree (required if recharge/payment via Cashfree)
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=

#############################################
# CALL MASKING (EXOTEL)
#############################################
EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_VIRTUAL_NUMBER=
EXOTEL_BASE_URL=https://api.exotel.com/v1/Accounts
EXOTEL_CALLBACK_TOKEN=replace_with_long_random_secret

#############################################
# PUSH NOTIFICATION
#############################################
# FCM API mode: auto|v1|legacy
FCM_PREFERRED_API=auto
FIREBASE_PROJECT_ID=
FCM_SERVER_KEY=

#############################################
# SUPER ADMIN BOOTSTRAP
#############################################
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@admin.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
